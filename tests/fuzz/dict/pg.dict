# libFuzzer dictionary for the PG-shaped targets (fuzz_pg, fuzz_pipe; Р51).
# Message type bytes, wire magics and SQL fragments the mutator would otherwise
# have to guess byte-by-byte. Passed with -dict= by campaign.sh and CI.

# --- v3 message tags: frontend ----------------------------------------------
tag_query="Q"
tag_parse="P"
tag_bind="B"
tag_execute="E"
tag_describe="D"
tag_close="C"
tag_sync="S"
tag_terminate="X"
tag_function="F"
tag_flush="H"
tag_copy_data="d"
tag_copy_done="c"
tag_copy_fail="f"
tag_password="p"

# --- v3 message tags: backend ------------------------------------------------
tag_auth="R"
tag_key_data="K"
tag_ready="Z"
tag_row_desc="T"
tag_data_row="D"
tag_complete="C"
tag_error="E"
tag_notice="N"
tag_param_status="S"
tag_parse_done="1"
tag_bind_done="2"
tag_close_done="3"
tag_no_data="n"
tag_empty_query="I"
tag_suspended="s"
tag_param_desc="t"
tag_notify="A"
tag_copy_in="G"
tag_copy_out="H"
tag_copy_both="W"
tag_negotiate="v"

# --- wire magics ---------------------------------------------------------------
proto_v3="\x00\x03\x00\x00"
ssl_request="\x00\x00\x00\x08\x04\xd2\x16\x2f"
gssenc_request="\x00\x00\x00\x08\x04\xd2\x16\x30"
cancel_request="\x00\x00\x00\x10\x04\xd2\x16\x2e"
ready_idle="Z\x00\x00\x00\x05I"
ready_txn="Z\x00\x00\x00\x05T"
ready_err="Z\x00\x00\x00\x05E"
auth_ok="R\x00\x00\x00\x08\x00\x00\x00\x00"
empty_msg_len="\x00\x00\x00\x04"
small_len="\x00\x00\x00\x0c"
huge_len="\x3f\xff\xff\xff"

# --- startup parameters ---------------------------------------------------------
kv_user="user\x00postgres\x00"
kv_database="database\x00postgres\x00"
kv_appname="application_name\x00"
kv_server_version="server_version\x00"

# --- error fields / command tags -------------------------------------------------
err_severity="SERROR\x00"
err_div_zero="C22012\x00"
err_unique="C23505\x00"
err_undefined="C42P01\x00"
err_message="Mdivision by zero\x00"
tag_select="SELECT 1\x00"
tag_insert="INSERT 0 5\x00"
tag_update="UPDATE 3\x00"
tag_copy="COPY 2\x00"
tag_begin="BEGIN\x00"

# --- SQL fragments (fuzz_norm shares the dictionary's tail) ----------------------
kw_select="select "
kw_insert="insert into "
kw_update="update "
kw_delete="delete from "
kw_values=" values (1, 'x'), (2, 'y')"
kw_where=" where id = "
kw_in=" in (1, 2, 3)"
kw_from=" from "
kw_join=" left join t on "
kw_group=" group by "
kw_order=" order by "
kw_limit=" limit 10"
kw_begin="begin"
kw_commit="commit"
kw_copy_in="copy t from stdin"
kw_copy_out="copy t to stdout"
kw_pg_sleep="select pg_sleep(0.1)"
sql_bind1="$1"
sql_bind_jdbc=" ? "
sql_quote="'it''s'"
sql_escape_str="E'a\\'b'"
sql_dollar="$tag$body$tag$"
sql_comment_line="-- comment\x0a"
sql_comment_open="/*"
sql_comment_close="*/"
sql_number="1_000.5e-3"
sql_hex="0xdeadbeef"
sql_quoted_ident="\x22MiXeD\x22"
sql_semicolon="; "
