# latkit environment configuration — the single systemd config surface (Р34/Р47).
#
#   sudo mkdir -p /etc/latkit && sudo cp latkit.env.example /etc/latkit/latkit.env
#   sudo systemctl restart latkit
#
# Every LATKIT_* variable mirrors a CLI flag; precedence is
# flag > LATKIT_* env > (OTEL_* env for the OTLP group) > built-in default.
# Verify the resolved config without touching BPF:
#   sudo env $(grep -v '^#' /etc/latkit/latkit.env | xargs) latkit --print-config
#
# Boolean variables accept 1/true/yes/on (anything else = off).
# Everything below is commented out and shows the built-in default.

# ---------------------------------------------------------------------------
# Capture filters — all active filters combine with AND (port AND comm AND cgroup)
# ---------------------------------------------------------------------------

# Local (server) ports to capture, comma-separated, up to 16.
#LATKIT_PORT=5432

# Only capture send/recv from processes with this exact comm.
#LATKIT_COMM=postgres

# Only capture traffic from cgroups whose path under /sys/fs/cgroup matches
# these globs (comma-separated; * stays within a path segment, ** spans
# segments). Requires cgroup v2. Example for a docker-run postgres:
#   LATKIT_CGROUP=system.slice/docker-*.scope
#LATKIT_CGROUP=

# ---------------------------------------------------------------------------
# Capture tuning
# ---------------------------------------------------------------------------

# BPF ringbuf size in bytes, power of two in [4096, 1G]. Grow when
# latkit_ringbuf_dropped_total is non-zero under your peak load.
#LATKIT_RINGBUF_BYTES=8388608

# Capture budget per send/recv call, bytes (1..16384). Payload past the budget
# is not copied, but message accounting stays honest (total_len).
#LATKIT_CAPTURE_LIMIT=8192

# Userspace connection table ceiling; least recently active entries are
# evicted past it.
#LATKIT_MAX_CONNS=65536

# Evict connections without events for this many seconds.
#LATKIT_CONN_IDLE_TIMEOUT=600

# ---------------------------------------------------------------------------
# Metrics shaping
# ---------------------------------------------------------------------------

# Distinct normalised queries tracked before the rest fold into query="other".
# The main cardinality knob: series ≈ queries × (db,user) pairs.
#LATKIT_TOP_QUERIES=500

# Max characters of the normalised text kept as the `query` label.
#LATKIT_QUERY_LABEL_LEN=256

# Also record latkit_query_first_row_seconds (time to first row; doubles the
# query-labelled series count). Boolean.
#LATKIT_FIRST_ROW_HIST=0

# ---------------------------------------------------------------------------
# Prometheus exposition
# ---------------------------------------------------------------------------

# Address for /metrics and /healthz; 'none' disables the listener.
# The default binds loopback (Р29) — scraping from another host needs 0.0.0.0
# (there is no TLS/auth on this endpoint; keep it inside your scrape network).
#LATKIT_PROM_LISTEN=127.0.0.1:9752

# ---------------------------------------------------------------------------
# OTLP push exporter (optional; also honours the standard OTEL_* variables)
# ---------------------------------------------------------------------------

# Collector base URL (http:// only); setting it enables the exporter.
# Falls back to $OTEL_EXPORTER_OTLP_ENDPOINT.
#LATKIT_OTLP_ENDPOINT=http://collector:4318

# Export period, seconds.
#LATKIT_OTLP_INTERVAL=15

# service.name in the OTLP resource. Falls back to $OTEL_SERVICE_NAME.
#LATKIT_OTLP_SERVICE_NAME=latkit

# Extra request headers (auth), comma-separated K=V pairs.
# Falls back to $OTEL_EXPORTER_OTLP_HEADERS.
#LATKIT_OTLP_HEADERS=authorization=Bearer secret

# Extra resource attributes, comma-separated K=V pairs.
# Falls back to $OTEL_RESOURCE_ATTRIBUTES.
#LATKIT_OTLP_RESOURCE=deployment.environment=prod

# Sample this fraction [0,1] of queries as OTLP spans. Off by default.
# SECURITY: spans carry literal SQL unless LATKIT_OTLP_SPAN_MASKED is set (Р32).
#LATKIT_OTLP_SPANS=0

# Additionally sample every query at least this many ms long as a span.
#LATKIT_OTLP_SPANS_SLOW_MS=0

# Cap db.query.text at this many bytes.
#LATKIT_OTLP_SPAN_TEXT_MAX=4096

# Send the normalised (literal-free) SQL as db.query.text instead of the raw
# text. Boolean.
#LATKIT_OTLP_SPAN_MASKED=0

# ---------------------------------------------------------------------------
# TLS capture (stage 6)
# ---------------------------------------------------------------------------

# auto|off. 'auto' scans /proc for the libssl of matching processes, attaches
# SSL_read/SSL_write uprobes and rescans every 30 s. Needs CAP_SYS_PTRACE +
# CAP_SYS_ADMIN in the unit's CapabilityBoundingSet (see latkit.service).
#LATKIT_TLS=off

# Attach the SSL_* uprobes to this exact libssl path, skipping the /proc scan
# (e.g. a container's copy visible under /proc/<pid>/root/...).
#LATKIT_LIBSSL=

# With LATKIT_TLS=auto, scan only processes with this comm.
#LATKIT_TLS_COMM=postgres

# ---------------------------------------------------------------------------
# Debug / diagnostics (all off by default; noisy — not for production)
# ---------------------------------------------------------------------------

# Append every raw ringbuf record to this file for offline replay (LKT1 trace).
# Remember to whitelist the directory via ReadWritePaths= in latkit.service.
#LATKIT_RECORD=

# One line per raw ringbuf event / reassembled message / query observation.
# Booleans.
#LATKIT_EVENTS=0
#LATKIT_MESSAGES=0
#LATKIT_QUERIES=0

# Hexdump payloads of LATKIT_EVENTS / LATKIT_MESSAGES output. Boolean.
#LATKIT_HEXDUMP=0

# Write the Prometheus exposition on SIGUSR1 and at exit: a bare boolean means
# stderr, any other value is the target path.
#LATKIT_DUMP_METRICS=0

# Test hook: switch every connection to HEADERS capture mode at OPEN. Boolean.
#LATKIT_CAP_HEADERS=0
