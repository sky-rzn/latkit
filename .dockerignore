# Keep the release-image build context (deploy/docker/Dockerfile) to the
# sources: no local build trees or scratch files. .git stays in — the builder
# stamps the version from `git describe`.
build/
build-*/
demo/
dump.txt
# ...except the host-built dev binary the e2e stand copies into its image
# (tests/e2e/Dockerfile.latkit); the release Dockerfile builds from source
# and never references it.
!build/latkit
